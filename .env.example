# =============================================================================
# GovOn Runtime — 컨테이너 기본 프로필 (.env)
# =============================================================================
# 사용법:
#   1) cp .env.example .env
#   2) 필요한 값(API_KEY, MODEL_PATH 등) 수정
#   3) docker compose up -d --build

# --- 서빙 프로필 ---
SERVING_PROFILE=container

# --- 서버 ---
HOST=0.0.0.0
PORT=8000
HOST_PORT=8000
LOG_LEVEL=INFO
RELOAD=false
# Uvicorn 워커 수 (컨테이너 프로필 기본값: 1)
WORKERS=1
# vLLM 내부 서빙 포트 (api_server 내부에서 vLLM에 접근할 때 사용)
VLLM_PORT=8000

# --- 모델 ---
MODEL_PATH=LGAI-EXAONE/EXAONE-4.0-32B-AWQ
TRUST_REMOTE_CODE=true
MODEL_DTYPE=half
ENFORCE_EAGER=true
GPU_UTILIZATION=0.8
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false

# --- Multi-LoRA 어댑터 ---
# 형식: "name=path_or_hf_repo_id,name=path_or_hf_repo_id"
# HF Hub repo ID 사용 시: ADAPTER_PATHS=civil=umyunsang/govon-civil-adapter,legal=siwo/govon-legal-adapter
# 로컬 경로 사용 시: ADAPTER_PATHS=civil=/app/models/adapters/civil-adapter,legal=/app/models/adapters/legal-adapter
# 빈 값이면 LoRA 비활성화 (base model만 사용)
ADAPTER_PATHS=

# --- 데이터 경로 (컨테이너 내부 경로 기준) ---
DATA_PATH=/app/data/processed/v2_train.jsonl
INDEX_PATH=/app/models/faiss_index/complaints.index
FAISS_INDEX_DIR=/app/models/faiss_index
BM25_INDEX_DIR=/app/models/bm25_index
AGENTS_DIR=/app/agents
# 로컬 문서 루트 디렉터리 (비워두면 비활성화)
LOCAL_DOCS_ROOT=

# --- 로그 / 캐시 ---
LOG_DIR=/var/log/govon
CACHE_DIR=/app/.cache

# --- DB·세션 ---
# GovOn 홈 디렉터리 (세션 DB 등 로컬 데이터 저장 위치)
# 주의: ~ 는 쉘에서만 확장됨. 절대경로 권장.
GOVON_HOME=/home/user/.govon
# 메인 데이터베이스 URL (기본: GOVON_HOME 아래 SQLite)
# SQLite 절대경로는 슬래시 4개 필요: sqlite:////절대경로
DATABASE_URL=sqlite:////home/user/.govon/metadata.sqlite3
# 세션 데이터베이스 경로 (기본: GOVON_HOME/sessions.db)
GOVON_SESSION_DB=
# SQL 쿼리 에코 출력 (디버그용, true/false)
SQL_ECHO=false

# --- 보안·인증 ---
API_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# API_KEY 없이 접근 허용 (개발 환경 전용, 프로덕션에서는 반드시 false)
ALLOW_NO_AUTH=false

# --- Rate Limiting / 타임아웃 ---
RATE_LIMIT_ENABLED=true
REQUEST_TIMEOUT_SEC=60

# --- Generation Defaults ---
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1

# --- Feature Flags ---
USE_RAG_PIPELINE=true
MODEL_VERSION=v2_lora

# --- 검색 인덱스 무결성 ---
BM25_INDEX_HMAC_KEY=your_hmac_key_for_bm25_integrity

# --- 외부 API ---
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# --- LangGraph 모델 어댑터 (vLLM OpenAI-compatible endpoint) ---
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:8001/v1
LANGGRAPH_MODEL_API_KEY=EMPTY

# --- 헬스체크 ---
HEALTH_INTERVAL_SEC=30
HEALTH_TIMEOUT_SEC=10

# --- CLI ---
# CLI 데몬이 접속하는 런타임 포트 (daemon.py)
GOVON_PORT=8000
# CLI 셸이 접속하는 런타임 URL (미설정 시 자동 감지)
GOVON_RUNTIME_URL=

# --- Docker Compose ---
# 빌드된 이미지 이름
GOVON_IMAGE=govon-backend:latest
# 컨테이너 이름
GOVON_CONTAINER_NAME=govon-backend
