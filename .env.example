# =============================================================================
# GovOn Runtime — 컨테이너 기본 프로필 (.env)
# =============================================================================
# 사용법:
#   1) cp .env.example .env
#   2) 필요한 값(API_KEY, MODEL_PATH 등) 수정
#   3) docker compose up -d --build

# --- 서빙 프로필 ---
SERVING_PROFILE=container

# --- 서버 ---
HOST=0.0.0.0
PORT=8000
HOST_PORT=8000
LOG_LEVEL=INFO
RELOAD=false
WORKERS=1  # uvicorn worker 수 (성능 튜닝; 기본값 1)

# --- 모델 ---
MODEL_PATH=umyunsang/GovOn-EXAONE-AWQ-v2
TRUST_REMOTE_CODE=true
MODEL_DTYPE=half
ENFORCE_EAGER=true
GPU_UTILIZATION=0.8
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false

# --- 데이터 경로 (컨테이너 내부 경로 기준) ---
DATA_PATH=/app/data/processed/v2_train.jsonl
INDEX_PATH=/app/models/faiss_index/complaints.index
FAISS_INDEX_DIR=/app/models/faiss_index
BM25_INDEX_DIR=/app/models/bm25_index
AGENTS_DIR=/app/agents

# --- 로그 / 캐시 ---
LOG_DIR=/var/log/govon
CACHE_DIR=/app/.cache

# --- 보안 ---
API_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Rate Limiting / 타임아웃 ---
RATE_LIMIT_ENABLED=true
REQUEST_TIMEOUT_SEC=60

# --- Generation Defaults ---
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1

# --- Feature Flags ---
USE_RAG_PIPELINE=true
MODEL_VERSION=v2_lora

# --- 검색 인덱스 무결성 ---
BM25_INDEX_HMAC_KEY=your_hmac_key_for_bm25_integrity

# --- 외부 API ---
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# --- LangGraph 모델 어댑터 (vLLM OpenAI-compatible endpoint) ---
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:8001/v1
LANGGRAPH_MODEL_API_KEY=EMPTY
LANGGRAPH_PLANNER_MODEL=  # planner 전용 모델 별도 지정 (비워두면 LANGGRAPH_MODEL_BASE_URL 기본 모델 사용)

# --- Multi-LoRA 어댑터 경로 (vLLM --lora-modules 형식) ---
# LoRA 어댑터가 준비된 경우 아래 형식으로 경로를 지정한다.
# 형식: "civil=/path/to/civil-adapter,legal=/path/to/legal-adapter"
# 비워두면 base model만 사용한다 (LoRA 비활성화).
ADAPTER_PATHS=

# --- DB 설정 ---
DATABASE_URL=sqlite:///~/.govon/metadata.sqlite3  # SQLAlchemy DB URL (기본값: ~/.govon/metadata.sqlite3)
GOVON_HOME=~/.govon  # GovOn 홈 디렉토리 (세션DB, 로그, 캐시 기본 위치)
GOVON_SESSION_DB=  # 세션 DB 경로 오버라이드 (비워두면 GOVON_HOME 기본값 사용)

# --- 디버그 ---
SQL_ECHO=false  # SQLAlchemy 쿼리 로깅 활성화 (디버그용; 프로덕션에서는 false)

# --- 헬스체크 ---
HEALTH_INTERVAL_SEC=30
HEALTH_TIMEOUT_SEC=10
