# HuggingFace Spaces 배포용 환경변수
SERVING_PROFILE=container
HOST=0.0.0.0
PORT=7860
MODEL_PATH=LGAI-EXAONE/EXAONE-4.0-32B-AWQ
TRUST_REMOTE_CODE=true
MODEL_DTYPE=half
ENFORCE_EAGER=true
GPU_UTILIZATION=0.85
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false
# 개발/테스트용 와일드카드. 프로덕션에서는 특정 도메인으로 제한 필요
CORS_ORIGINS=*
RATE_LIMIT_ENABLED=true
REQUEST_TIMEOUT_SEC=300
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:7860/v1
LANGGRAPH_MODEL_API_KEY=EMPTY
# HF Spaces Secrets로 설정할 것:
# HF_TOKEN=hf_...
# API_KEY=your-api-key
# --- Multi-LoRA 어댑터 (HF Hub repo ID — vLLM이 자동 다운로드) ---
# civil: 민원 초안 생성(draft_civil_response), legal: 법률 근거 인용(append_evidence)
ADAPTER_PATHS=civil=umyunsang/govon-civil-adapter,legal=siwo/govon-legal-adapter
