# Dockerfile.ci — lightweight image for compose-smoke only
# Excludes ML packages (torch, vllm, autoawq, etc.) — validates API startup only with SKIP_MODEL_LOAD=true

FROM python:3.14-slim

LABEL org.opencontainers.image.description="GovOn CI smoke-test image (no ML packages)"

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    SERVING_PROFILE="container" \
    SKIP_MODEL_LOAD="true" \
    MODEL_PATH="LGAI-EXAONE/EXAONE-4.0-32B-AWQ" \
    DATA_PATH="/app/data/processed/v2_train.jsonl" \
    INDEX_PATH="/app/models/faiss_index/complaints.index"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir uv

COPY requirements.txt .

# Auto-install everything except ML packages
RUN grep -ivE '^(torch|vllm|autoawq|bitsandbytes|peft|trl|optimum|accelerate|datasets|transformers|sentence.transformers|unsloth|xformers|triton|flash.attn|nvidia)' requirements.txt > /tmp/ci-reqs.txt \
    && uv pip install --system --no-cache -r /tmp/ci-reqs.txt \
    && uv pip install --system --no-cache sentence-transformers --no-deps

COPY src/ ./src/
COPY agents/ ./agents/

RUN mkdir -p models/faiss_index models/bm25_index data/processed

EXPOSE 8000

RUN groupadd -r govon && useradd -r -g govon -d /app govon
RUN chown -R govon:govon /app
USER govon

CMD ["python3.10", "-m", "src.inference.api_server"]
