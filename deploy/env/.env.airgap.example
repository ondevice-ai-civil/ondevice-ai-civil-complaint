# =============================================================================
# GovOn Runtime — Air-gap (offline) installation profile (.env.airgap)
# =============================================================================
# Usage: cp .env.airgap.example .env
# Note: compose injects this file as container environment variables,
#       so paths must use container-internal paths (/app/...), not host paths.

# --- Serving Profile ---
SERVING_PROFILE=airgap

# --- Server ---
HOST=0.0.0.0
PORT=8000
HOST_PORT=8000
LOG_LEVEL=INFO
RELOAD=false

# --- Model (container-internal path) ---
MODEL_PATH=/app/models/EXAONE-4.0-32B-AWQ
GPU_UTILIZATION=0.8
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false
TRUST_REMOTE_CODE=true

# --- Multi-LoRA Adapters (air-gap: container-internal local paths) ---
# Prerequisites: download adapters with huggingface-cli and place in ./models/adapters/
# (passed to container via ./models:/app/models volume mount in docker-compose.yml)
ADAPTER_PATHS=civil=/app/models/adapters/civil-adapter,legal=/app/models/adapters/legal-adapter

# --- Data Paths (container-internal paths) ---
DATA_PATH=/app/data/processed/v2_train.jsonl
INDEX_PATH=/app/models/faiss_index/complaints.index
FAISS_INDEX_DIR=/app/models/faiss_index
BM25_INDEX_DIR=/app/models/bm25_index
AGENTS_DIR=/app/agents

# --- Log / Cache ---
LOG_DIR=/var/log/govon
CACHE_DIR=/app/.cache

# --- Security (required) ---
# Replace with a unique random string before deployment.
API_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY
CORS_ORIGINS=http://10.0.0.100:3000

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true

# --- Timeout ---
REQUEST_TIMEOUT_SEC=90

# --- Generation Defaults ---
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1

# --- Feature Flags ---
USE_RAG_PIPELINE=true
MODEL_VERSION=v2_lora

# --- LangGraph Model Adapter ---
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:8001/v1
LANGGRAPH_MODEL_API_KEY=EMPTY

# --- Search Index Integrity (required) ---
# Replace with a unique random string before deployment.
BM25_INDEX_HMAC_KEY=CHANGE_ME_TO_SECURE_HMAC_KEY

# --- Health Check ---
HEALTH_INTERVAL_SEC=30
HEALTH_TIMEOUT_SEC=10

# --- Air-gap specific settings ---
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
