# =============================================================================
# GovOn Runtime — Container base profile (.env)
# =============================================================================
# Usage:
#   1) cp .env.example .env
#   2) Set required values (API_KEY, MODEL_PATH, etc.)
#   3) docker compose up -d --build

# --- Serving Profile ---
SERVING_PROFILE=container

# --- Server ---
HOST=0.0.0.0
PORT=8000
HOST_PORT=8000
LOG_LEVEL=INFO
RELOAD=false
# Uvicorn worker count (container profile default: 1)
WORKERS=1
# vLLM internal serving port (used by api_server to connect to vLLM internally)
VLLM_PORT=8000

# --- Model ---
MODEL_PATH=LGAI-EXAONE/EXAONE-4.0-32B-AWQ
TRUST_REMOTE_CODE=true
MODEL_DTYPE=half
ENFORCE_EAGER=true
GPU_UTILIZATION=0.8
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false

# --- Multi-LoRA Adapters ---
# Format: "name=path_or_hf_repo_id,name=path_or_hf_repo_id"
# HF Hub repo ID: ADAPTER_PATHS=civil=umyunsang/govon-civil-adapter,legal=siwo/govon-legal-adapter
# Local path: ADAPTER_PATHS=civil=/app/models/adapters/civil-adapter,legal=/app/models/adapters/legal-adapter
# Leave empty to disable LoRA (base model only)
ADAPTER_PATHS=

# --- Data Paths (relative to container internal path) ---
DATA_PATH=/app/data/processed/v2_train.jsonl
INDEX_PATH=/app/models/faiss_index/complaints.index
FAISS_INDEX_DIR=/app/models/faiss_index
BM25_INDEX_DIR=/app/models/bm25_index
AGENTS_DIR=/app/agents
# Local document root directory (leave empty to disable)
LOCAL_DOCS_ROOT=

# --- Log / Cache ---
LOG_DIR=/var/log/govon
CACHE_DIR=/app/.cache

# --- DB / Session ---
# GovOn home directory (storage location for local data such as session DB)
# Note: ~ is only expanded in shell. Absolute path recommended.
GOVON_HOME=/home/user/.govon
# Main database URL (default: SQLite under GOVON_HOME)
# SQLite absolute path requires four slashes: sqlite:////absolute/path
DATABASE_URL=sqlite:////home/user/.govon/metadata.sqlite3
# Session database path (default: GOVON_HOME/sessions.db)
GOVON_SESSION_DB=
# Echo SQL queries (for debugging, true/false)
SQL_ECHO=false

# --- Security / Auth ---
API_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Allow access without API_KEY (development only, must be false in production)
ALLOW_NO_AUTH=false

# --- Rate Limiting / Timeout ---
RATE_LIMIT_ENABLED=true
REQUEST_TIMEOUT_SEC=60

# --- Generation Defaults ---
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1

# --- Feature Flags ---
USE_RAG_PIPELINE=true
MODEL_VERSION=v2_lora

# --- Search Index Integrity ---
BM25_INDEX_HMAC_KEY=your_hmac_key_for_bm25_integrity

# --- External API ---
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# --- LangGraph Model Adapter (vLLM OpenAI-compatible endpoint) ---
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:8001/v1
LANGGRAPH_MODEL_API_KEY=EMPTY

# --- Health Check ---
HEALTH_INTERVAL_SEC=30
HEALTH_TIMEOUT_SEC=10

# --- CLI ---
# Runtime port the CLI daemon connects to (daemon.py)
GOVON_PORT=8000
# Runtime URL the CLI shell connects to (auto-detected if not set)
GOVON_RUNTIME_URL=

# --- Docker Compose ---
# Built image name
GOVON_IMAGE=govon-backend:latest
# Container name
GOVON_CONTAINER_NAME=govon-backend
