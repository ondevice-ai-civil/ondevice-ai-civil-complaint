# HuggingFace Spaces deployment environment variables
SERVING_PROFILE=container
HOST=0.0.0.0
PORT=7860
MODEL_PATH=LGAI-EXAONE/EXAONE-4.0-32B-AWQ
TRUST_REMOTE_CODE=true
MODEL_DTYPE=half
ENFORCE_EAGER=true
GPU_UTILIZATION=0.85
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false
# Wildcard for development/testing. Restrict to specific domains in production.
CORS_ORIGINS=*
RATE_LIMIT_ENABLED=true
REQUEST_TIMEOUT_SEC=300
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:7860/v1
LANGGRAPH_MODEL_API_KEY=EMPTY
# Set via HF Spaces Secrets:
# HF_TOKEN=hf_...
# API_KEY=your-api-key
# --- Multi-LoRA Adapters (HF Hub repo ID — downloaded automatically by vLLM) ---
# civil: public administration complaint response generation, legal: legal interpretation and citation response
ADAPTER_PATHS=civil=umyunsang/govon-civil-adapter,legal=siwo/govon-legal-adapter
