# =============================================================================
# GovOn Runtime — Local development profile (.env.local)
# =============================================================================
# Usage: cp .env.local.example .env && uvicorn src.inference.api_server:app --reload

# --- Serving Profile ---
SERVING_PROFILE=local

# --- Server ---
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=DEBUG
RELOAD=true

# --- Model ---
MODEL_PATH=LGAI-EXAONE/EXAONE-4.0-32B-AWQ
GPU_UTILIZATION=0.7
MAX_MODEL_LEN=4096
# Set to true to start the API server without loading the model
SKIP_MODEL_LOAD=false

# --- Multi-LoRA Adapters (for local development) ---
# HF Hub: ADAPTER_PATHS=civil=umyunsang/govon-civil-adapter,legal=siwo/govon-legal-adapter
# Leave empty to disable LoRA
ADAPTER_PATHS=

# --- Data Paths ---
DATA_PATH=data/processed/v2_train.jsonl
INDEX_PATH=models/faiss_index/complaints.index
FAISS_INDEX_DIR=models/faiss_index
BM25_INDEX_DIR=models/bm25_index

# --- Log / Cache ---
LOG_DIR=logs
CACHE_DIR=.cache

# --- Security ---
# In local development, authentication is skipped when API_KEY is not set
# API_KEY=dev_test_key
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=false

# --- Timeout ---
REQUEST_TIMEOUT_SEC=120

# --- Generation Defaults ---
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1

# --- Feature Flags ---
USE_RAG_PIPELINE=true
MODEL_VERSION=v2_lora

# --- LangGraph Model Adapter ---
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:8001/v1
LANGGRAPH_MODEL_API_KEY=EMPTY

# --- Search Index Integrity ---
# BM25_INDEX_HMAC_KEY=dev_hmac_key

# --- Health Check ---
HEALTH_INTERVAL_SEC=30
HEALTH_TIMEOUT_SEC=10
