# =============================================================================
# GovOn Runtime — Single-server production profile (.env.prod)
# =============================================================================
# Usage: cp .env.prod.example .env

# --- Serving Profile ---
SERVING_PROFILE=single

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
RELOAD=false

# --- Model ---
MODEL_PATH=LGAI-EXAONE/EXAONE-4.0-32B-AWQ
GPU_UTILIZATION=0.85
MAX_MODEL_LEN=8192
SKIP_MODEL_LOAD=false

# --- Multi-LoRA Adapters ---
ADAPTER_PATHS=civil=umyunsang/govon-civil-adapter,legal=siwo/govon-legal-adapter

# --- Data Paths ---
DATA_PATH=/app/data/processed/v2_train.jsonl
INDEX_PATH=/app/models/faiss_index/complaints.index
FAISS_INDEX_DIR=/app/models/faiss_index
BM25_INDEX_DIR=/app/models/bm25_index
AGENTS_DIR=/app/agents

# --- Log / Cache ---
LOG_DIR=/var/log/govon
CACHE_DIR=/app/.cache

# --- Security (required) ---
API_KEY=CHANGE_ME_TO_SECURE_RANDOM_KEY
CORS_ORIGINS=https://govon.example.com

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true

# --- Timeout ---
REQUEST_TIMEOUT_SEC=60

# --- Generation Defaults ---
GEN_MAX_TOKENS=512
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_REPETITION_PENALTY=1.1

# --- Feature Flags ---
USE_RAG_PIPELINE=true
MODEL_VERSION=v2_lora

# --- LangGraph Model Adapter ---
LANGGRAPH_MODEL_BASE_URL=http://127.0.0.1:8001/v1
LANGGRAPH_MODEL_API_KEY=EMPTY

# --- Search Index Integrity (required) ---
BM25_INDEX_HMAC_KEY=CHANGE_ME_TO_SECURE_HMAC_KEY

# --- Health Check ---
HEALTH_INTERVAL_SEC=30
HEALTH_TIMEOUT_SEC=10
